{
    "name": "reefki/laravel-flip",
    "description": "Fluent Laravel SDK for the Flip for Business (flip.id) payment API.",
    "keywords": ["laravel", "flip", "flip.id", "disbursement", "payment", "indonesia", "remittance"],
    "license": "MIT",
    "type": "library",
    "support": {
        "issues": "https://github.com/reefki/laravel-flip/issues",
        "source": "https://github.com/reefki/laravel-flip"
    },
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.5",
        "illuminate/contracts": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "pestphp/pest": "^2.0|^3.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Reefki\\Flip\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Reefki\\Flip\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Reefki\\Flip\\FlipServiceProvider"
            ],
            "aliases": {
                "Flip": "Reefki\\Flip\\Facades\\Flip"
            }
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
